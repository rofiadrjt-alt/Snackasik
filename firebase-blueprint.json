{
  "entities": {
    "siteSettings": {
      "title": "Site Settings",
      "description": "General configuration for the landing page",
      "type": "object",
      "properties": {
        "headline": { "type": "string" },
        "description": { "type": "string" },
        "heroImage": { "type": "string" },
        "processImage": { "type": "string" },
        "processHeadline": { "type": "string" },
        "processDescription": { "type": "string" },
        "processBadge": { "type": "string" },
        "featuresHeadline": { "type": "string" },
        "featuresDescription": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "shopeeLink": { "type": "string" },
        "tokopediaLink": { "type": "string" },
        "location": { "type": "string" },
        "instagramLink": { "type": "string" },
        "tiktokLink": { "type": "string" },
        "faviconUrl": { "type": "string" },
        "facebookLink": { "type": "string" },
        "youtubeLink": { "type": "string" },
        "googleSiteVerification": { "type": "string" },
        "googleAnalyticsId": { "type": "string" },
        "googleTagManagerId": { "type": "string" },
        "headScripts": { "type": "string" },
        "bodyScripts": { "type": "string" }
      },
      "required": ["headline", "description", "whatsappNumber"]
    },
    "product": {
      "title": "Product",
      "description": "A snack product item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "weight": { "type": "string" },
        "order": { "type": "number" },
        "link": { "type": "string" }
      },
      "required": ["name", "price", "imageUrl"]
    },
    "testimonial": {
      "title": "Testimonial",
      "description": "Customer feedback",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "text": { "type": "string" },
        "role": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "text"]
    },
    "faq": {
      "title": "FAQ",
      "description": "Frequently Asked Question",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["question", "answer"]
    },
    "article": {
      "title": "Article",
      "description": "Blog post or news article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "slug", "content"]
    }
  },
  "firestore": {
    "settings/general": {
      "schema": "siteSettings",
      "description": "Global settings for the website"
    },
    "products/{productId}": {
      "schema": "product",
      "description": "Snack products collection"
    },
    "testimonials/{testimonialId}": {
      "schema": "testimonial",
      "description": "Customer testimonials"
    },
    "faqs/{faqId}": {
      "schema": "faq",
      "description": "FAQ items"
    },
    "articles/{articleId}": {
      "schema": "article",
      "description": "Blog articles"
    },
    "admins/{userId}": {
      "schema": "object",
      "description": "System administrators"
    }
  }
}
